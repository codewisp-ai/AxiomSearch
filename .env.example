# ====================================================================
# AxiomSearch Core Configuration Template
# Copy this file to a new file named '.env' and fill in your actual keys.
# ====================================================================

# FastAPI Settings
PORT=8000
HOST=0.0.0.0

# Google Gemini API Key (Used for Core Reasoning & Synthesis)
# Get one from Google AI Studio
GOOGLE_API_KEY=your_gemini_api_key_here

# Search API Key (Used by the Crawler Node to fetch live web data)
# Get one from tavily.com
TAVILY_API_KEY=your_tavily_api_key_here